{
  "name": "@tetrascience-npm/tetrascience-react-ui",
  "version": "0.5.0",
  "description": "TetraScience React UI",
  "type": "module",
  "author": "TetraScience",
  "license": "Apache-2.0",
  "sideEffects": [
    "./dist/index.css",
    "./dist/index.tailwind.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.cjs"
      }
    },
    "./server/providers/athena": {
      "import": {
        "types": "./dist/providers/athena.d.ts",
        "default": "./dist/providers/athena.js"
      },
      "require": {
        "types": "./dist/providers/athena.d.ts",
        "default": "./dist/providers/athena.cjs"
      }
    },
    "./server/providers/snowflake": {
      "import": {
        "types": "./dist/providers/snowflake.d.ts",
        "default": "./dist/providers/snowflake.js"
      },
      "require": {
        "types": "./dist/providers/snowflake.d.ts",
        "default": "./dist/providers/snowflake.cjs"
      }
    },
    "./server/providers/databricks": {
      "import": {
        "types": "./dist/providers/databricks.d.ts",
        "default": "./dist/providers/databricks.js"
      },
      "require": {
        "types": "./dist/providers/databricks.d.ts",
        "default": "./dist/providers/databricks.cjs"
      }
    },
    "./index.css": "./dist/index.css",
    "./index.tailwind.css": "./dist/index.tailwind.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:storybook": "vitest run --project=storybook",
    "test:storybook:watch": "vitest --project=storybook",
    "test:storybook:coverage": "vitest run --project=storybook --coverage",
    "test:storybook:ci": "vitest run --project=storybook --reporter=junit --outputFile=test-results/storybook-junit.xml",
    "test:storybook:ci:coverage": "vitest run --project=storybook --reporter=junit --outputFile=test-results/storybook-junit.xml --coverage",
    "test:all": "vitest run",
    "test:all:coverage": "vitest run --coverage",
    "build": "vite build && yarn run postbuild",
    "postbuild": "yarn dlx @tailwindcss/cli@4.2.2 -i ./src/index.tailwind.css -o ./dist/index.tailwind.css --minify",
    "dev": "yarn storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "prepublishOnly": "yarn run build",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": ">=3.0.0 <4.0.0",
    "@aws-sdk/client-sqs": ">=3.0.0 <4.0.0",
    "@aws-sdk/client-ssm": ">=3.0.0 <4.0.0",
    "@aws-sdk/lib-storage": ">=3.0.0 <4.0.0",
    "@base-ui/react": "^1.2.0",
    "@dagrejs/dagre": "^1.1.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-table": "^8.21.3",
    "@tetrascience-npm/ts-connectors-sdk": "^3.2.0",
    "@xyflow/react": "^12.6.4",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.9.0",
    "monaco-editor": "^0.52.2",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "plotly.js": "^3.0.1",
    "plotly.js-dist": "^2.35.2",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^4.7.1",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@aws-sdk/client-athena": "^3.0.0",
    "@databricks/sql": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "snowflake-sdk": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-athena": {
      "optional": true
    },
    "@databricks/sql": {
      "optional": true
    },
    "snowflake-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-athena": "^3.975.0",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@databricks/sql": "^1.12.0",
    "@eslint/js": "^9.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-links": "^10.2.15",
    "@storybook/addon-themes": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/builder-vite": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@tailwindcss/vite": "^4.2.2",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/jsdom": "^27",
    "@types/node": "^25.3.3",
    "@types/plotly.js": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-plotly.js": "^2.6.3",
    "@types/react-syntax-highlighter": "^15",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser": "^3",
    "@vitest/coverage-v8": "^3",
    "cookie-parser": "^1.4.7",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-storybook": "^10.2.15",
    "eslint-plugin-unicorn": "^63.0.0",
    "fast-xml-parser": "^5.3.4",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.89.0",
    "semantic-release": "^25.0.3",
    "shadcn": "^3.8.5",
    "snowflake-sdk": "^2.3.3",
    "storybook": "^10.2.15",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^27.0.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3"
  },
  "resolutions": {
    "jackspeak": "2.1.1",
    "typescript": "5.6.3"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  },
  "packageManager": "yarn@4.12.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetrascience/ts-lib-ui-kit.git"
  },
  "keywords": [
    "tetrascience",
    "react",
    "ui"
  ],
  "bugs": {
    "url": "https://github.com/tetrascience/ts-lib-ui-kit/issues"
  },
  "homepage": "https://github.com/tetrascience/ts-lib-ui-kit#readme"
}
